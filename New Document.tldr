						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "    - undefined (variable is delared but not initialized then default value assigned by JS engine is undefined)"
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "    - null (nothing, can be used to intentionally make variable empty)"
								}
							]
						},
